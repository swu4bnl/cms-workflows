{
  "tiled": {
    "uri": "https://tiled.nsls2.bnl.gov",
    "catalog_path": "cms/raw"
  },
  "outputs": {
    "directory": "stitching_outputs",
    "index_filename": "validation_index.json",
    "image_format": "tiff",
    "image_extension": ".tiff",
    "subfolder_template": "{detector}/{stitched_token}",
    "filename_rule": {
      "source": "tiled_start_filename",
      "replace_tile_label_with": "{stitched_token}",
      "append_if_tile_label_missing": true,
      "stitched_token_template": "stitched_{mode}"
    }
  },
  "coordinate_system": {
    "x_sign": -1,
    "y_sign": -1,
    "array_origin": "upper_left"
  },
  "detector": {
    "image_streams": [
      {
        "name": "saxs",
        "image_key": "pilatus2m-1_image",
        "position_prefix": "SAXS",
        "pixel_size_um": 172.0,
        "mask_path": "configs/Dectris/Pilatus2M_gaps-mask.png"
      },
      {
        "name": "waxs",
        "image_key": "pilatus800k-1_image",
        "position_prefix": "WAXS",
        "pixel_size_um": 172.0,
        "mask_path": "configs/Dectris/Pilatus800k_gaps-mask.png"
      },
      {
        "name": "maxs",
        "image_key": "pilatus800k-2_image",
        "position_prefix": "MAXS",
        "pixel_size_um": 172.0,
        "mask_path": "configs/Dectris/Pilatus800k2_gaps-mask.png"
      }
    ]
  },
  "plotting": {
    "global_percentiles": [1.0, 99.5],
    "show_colorbar": false
  },
  "tiling_configs": {
    "ygaps": [
      {
        "label": "pos1",
        "detector_position": "lower",
        "SAXSy": 0.0,
        "SAXSx": 0.0,
        "WAXSy": 0.0,
        "WAXSx": 0.0,
        "MAXSy": 0.0,
        "MAXSx": 0.0
      },
      {
        "label": "pos2",
        "detector_position": "upper",
        "SAXSy": 5.16,
        "SAXSx": 0.0,
        "WAXSy": 5.16,
        "WAXSx": 0.0,
        "MAXSy": 5.16,
        "MAXSx": 0.0
      }
    ],
    "xygaps": [
      {
        "label": "pos1",
        "detector_position": "lower_left",
        "SAXSy": 0.0,
        "SAXSx": 0.0,
        "WAXSy": 0.0,
        "WAXSx": 0.0,
        "MAXSy": 0.0,
        "MAXSx": 0.0
      },
      {
        "label": "pos2",
        "detector_position": "upper_left",
        "SAXSy": 5.16,
        "SAXSx": 0.0,
        "WAXSy": 5.16,
        "WAXSx": 0.0,
        "MAXSy": 5.16,
        "MAXSx": 0.0
      },
      {
        "label": "pos4",
        "detector_position": "upper_right",
        "SAXSy": 5.16,
        "SAXSx": 5.16,
        "WAXSy": 5.16,
        "WAXSx": -5.16,
        "MAXSy": 5.16,
        "MAXSx": -5.16
      },
      {
        "label": "pos3",
        "detector_position": "lower_right",
        "SAXSy": 0.0,
        "SAXSx": 5.16,
        "WAXSy": 0.0,
        "WAXSx": -5.16,
        "MAXSy": 0.0,
        "MAXSx": -5.16
      }
    ]
  }
}
